# Google Service Account (from the downloaded JSON key)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n

# Server
PORT=3000
POLL_INTERVAL_MS=60000

# Google Spreadsheet IDs (from each form's linked sheet URL)
# Revenue tab: WHOP + Pay It Monthly payments logged here (DBS Business Worksheet)
REVENUE_SHEET_ID=
REVENUE_SHEET_NAME=Revenue

SHEET_SETTER_EOD=
SHEET_CLOSER_EOD=
SHEET_POST_CALL=
SHEET_COMPANY_EOD=
SHEET_SALES_EOD=
SHEET_AD_REPORTS=
SHEET_BOOKED_CALL=

# Calendly (optional: for full name/email/event in Discord when someone books)
# Create at https://developer.calendly.com/ – use Personal Access Token with user or organization scope
CALENDLY_ACCESS_TOKEN=

# Discord Webhook URLs (one per target channel)
DISCORD_WEBHOOK_DAILY_REPORTS=
DISCORD_WEBHOOK_CALL_NOTES=
DISCORD_WEBHOOK_AD_REPORTS=
DISCORD_WEBHOOK_BOOKED_CALL=
DISCORD_WEBHOOK_NEW_LEAD=
DISCORD_WEBHOOK_NO_SHOW=
DISCORD_WEBHOOK_FOLLOW_UP=
DISCORD_WEBHOOK_CLOSED_DEAL=

# WHOP payments (new + refunds → PAYMENTS; failed + disputes → FAILED_PAYMENTS)
DISCORD_WEBHOOK_PAYMENTS=
DISCORD_WEBHOOK_FAILED_PAYMENTS=

# Pay It Monthly uses same DISCORD_WEBHOOK_PAYMENTS; optional: PAYITMONTHLY_WEBHOOK_SECRET for verification

# Typeform onboarding (optional): on each Typeform submit, create a Drive folder + Discord setup
# Enable Google Drive API for the GCP project. Share the parent folder with the service account (Editor).
GOOGLE_DRIVE_ONBOARDING_PARENT_ID=
# Optional: subfolders inside each client folder, pipe-separated (default: 1. ONBOARDING|ADVERTISING|CONTENT|...). Drive forbids "/" in names; slashes become " - ".
# GOOGLE_DRIVE_CLIENT_SUBFOLDER_NAMES=
# Discord bot (not webhook). Required for hub mode (category + channels). Not used for template server creation (see user token below).
DISCORD_BOT_TOKEN=
# Server template: code from https://discord.new/xxxx (xxxx only). Guild name = Company (fallback: name / email).
DISCORD_GUILD_TEMPLATE_CODE=
# User OAuth2 access token with `guilds` scope — bots CANNOT call Discord's create-guild-from-template API; only a user token works. Expires; refresh via OAuth or re-authorize.
DISCORD_GUILD_TEMPLATE_USER_ACCESS_TOKEN=
# Hub server (optional): one guild + category per client when template vars are not set. Bot needs Manage Channels.
DISCORD_ONBOARDING_GUILD_ID=
# Comma-separated text channel names under each new category (hub mode only; default: general,documents,notes,questions)
DISCORD_ONBOARDING_CHANNEL_NAMES=general,documents,notes,questions
# Optional: only run onboarding for these Typeform form IDs (comma-separated). If empty, all forms trigger it.
# Those same IDs do NOT post to DISCORD_WEBHOOK_NEW_LEAD (onboarding stays out of #new-lead).
TYPEFORM_ONBOARDING_FORM_IDS=
# Optional: comma-separated form IDs that must never use DISCORD_WEBHOOK_NEW_LEAD (use if onboarding list is empty but you still want to exclude a form).
# TYPEFORM_EXCLUDE_NEW_LEAD_FORM_IDS=

# Optional: persistent state directory (Railway volume mount path)
# STATE_DIR=/data
